<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginHorizontal="10dp"
    android:layout_marginVertical="4dp"
    android:background="@drawable/bg_card_network"
    android:elevation="1dp"
    android:gravity="center_vertical"
    android:paddingVertical="12dp"
    android:paddingHorizontal="14dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <!-- Badge con número de canal -->
    <TextView
        android:id="@+id/tvChannelBadge"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_channel_badge"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:gravity="center"
        android:fontFamily="sans-serif-medium"
        tools:text="6" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="16dp">

        <TextView
            android:id="@+id/tvChannelTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            tools:text="Canal 6" />

        <TextView
            android:id="@+id/tvChannelFreq"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/text_dim"
            android:fontFamily="monospace"
            android:layout_marginTop="2dp"
            tools:text="2437 MHz" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tvChannelNetCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            tools:text="2 redes" />

        <TextView
            android:id="@+id/tvChannelSaturation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp"
            tools:text="Saturación: 20%" />

    </LinearLayout>

</LinearLayout>
