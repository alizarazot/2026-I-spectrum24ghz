<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginHorizontal="10dp"
    android:layout_marginVertical="4dp"
    android:background="@drawable/bg_card_network"
    android:elevation="1dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:paddingHorizontal="14dp">

        <!-- WiFi Signal Icon with circular background -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="14dp">

            <View
                android:id="@+id/viewIconBg"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_icon_circle" />

            <ImageView
                android:id="@+id/ivSignalIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_wifi_4"
                android:contentDescription="Intensidad de Señal"
                android:tint="@color/sig_strong" />

        </FrameLayout>

        <!-- Network Name and Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- SSID and Lock -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvSsid"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="14.5sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:ellipsize="end"
                    android:maxLines="1"
                    tools:text="MiRedWifi" />

                <ImageView
                    android:id="@+id/ivLockIcon"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/ic_lock"
                    android:contentDescription="Seguridad"
                    android:tint="@color/text_secondary" />

            </LinearLayout>

            <!-- BSSID -->
            <TextView
                android:id="@+id/tvBssid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="@color/text_dim"
                android:fontFamily="monospace"
                android:layout_marginTop="1dp"
                tools:text="AA:BB:CC:DD:EE:FF" />

            <!-- Channel and Security subtitle -->
            <TextView
                android:id="@+id/tvSubInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10.5sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp"
                tools:text="Canal 6  ·  WPA2-PSK  ·  2437 MHz" />

        </LinearLayout>

        <!-- Signal Strength Column -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/tvRssi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:fontFamily="monospace"
                tools:text="-54" />

            <TextView
                android:id="@+id/tvRssiUnit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="dBm"
                android:textSize="9sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="monospace"
                android:gravity="end"
                android:layout_gravity="end" />

        </LinearLayout>

    </LinearLayout>

    <!-- Signal Strength Progress Bar -->
    <ProgressBar
        android:id="@+id/progressSignal"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_marginHorizontal="14dp"
        android:layout_marginBottom="10dp"
        android:max="100"
        android:progressBackgroundTint="@color/divider" />

</LinearLayout>